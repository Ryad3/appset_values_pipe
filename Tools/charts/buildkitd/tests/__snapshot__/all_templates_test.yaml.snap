all manifests should be equal to the snapshot:
  1: |
    apiVersion: cilium.io/v2
    kind: CiliumNetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: buildkitd
        app.kubernetes.io/version: v0.26.2-rootless
        helm.sh/chart: buildkitd-0.1.2
      name: RELEASE-NAME-buildkitd-network-policy
    spec:
      endpointSelector: {}
      ingress:
        - fromEndpoints:
            - matchLabels:
                io.kubernetes.pod.namespace: bamboo
  2: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: buildkitd
        app.kubernetes.io/version: v0.26.2-rootless
        helm.sh/chart: buildkitd-0.1.2
      name: RELEASE-NAME-buildkitd
    spec:
      clusterIP: None
      ports:
        - name: buildkit
          port: 1234
          protocol: TCP
          targetPort: 1234
      selector:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/name: buildkitd
      type: ClusterIP
  3: |
    apiVersion: apps/v1
    kind: StatefulSet
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: buildkitd
        app.kubernetes.io/version: v0.26.2-rootless
        helm.sh/chart: buildkitd-0.1.2
        sidecar.istio.io/inject: "false"
      name: RELEASE-NAME-buildkitd
    spec:
      podManagementPolicy: Parallel
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: RELEASE-NAME
          app.kubernetes.io/name: buildkitd
      serviceName: RELEASE-NAME-buildkitd
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/name: buildkitd
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: rexel.nodepool
                        operator: In
                        values:
                          - delivery
          containers:
            - args:
                - --addr
                - tcp://0.0.0.0:1234
                - --oci-worker-no-process-sandbox
              image: moby/buildkit:v0.26.2-rootless
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 6
                initialDelaySeconds: 10
                periodSeconds: 10
                tcpSocket:
                  port: 1234
                timeoutSeconds: 1
              name: buildkitd
              readinessProbe:
                failureThreshold: 6
                initialDelaySeconds: 5
                periodSeconds: 5
                tcpSocket:
                  port: 1234
                timeoutSeconds: 1
              securityContext:
                appArmorProfile:
                  type: Unconfined
                runAsGroup: 1000
                runAsUser: 1000
                seccompProfile:
                  type: Unconfined
              volumeMounts:
                - mountPath: /home/user/.local/share/buildkit
                  name: buildkitd
          securityContext:
            fsGroup: 1000
          tolerations:
            - effect: NoSchedule
              key: dedicated
              operator: Equal
              value: delivery
            - effect: NoSchedule
              key: kubernetes.azure.com/scalesetpriority
              operator: Equal
              value: spot
          volumes:
            - ephemeral:
                volumeClaimTemplate:
                  spec:
                    accessModes:
                      - ReadWriteOnce
                    resources:
                      requests:
                        storage: 10Gi
                    storageClassName: managed-csi-premium
              name: buildkitd
